<UserControl x:Class="ClientMessenger.Views.ChattingRoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ClientMessenger.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="600">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!-- 메시지 목록 -->
            <RowDefinition Height="Auto" />
            <!-- 입력 영역 -->
        </Grid.RowDefinitions>

        <!-- 메시지 리스트 -->
        <ListBox Grid.Row="0"
                 ItemsSource="{Binding MessageList}"
                 BorderThickness="0"
                 Background="White"
                 Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding Sender}" FontWeight="Bold" />
                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Timestamp}" FontSize="10" Foreground="Gray" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 입력 영역 -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- 파일 버튼 -->
                <ColumnDefinition Width="Auto"/>
                <!-- 이미지 버튼 -->
                <ColumnDefinition Width="*" />
                <!-- 메시지 입력 -->
                <ColumnDefinition Width="Auto"/>
                <!-- 전송 버튼 -->
            </Grid.ColumnDefinitions>

            <!-- 이미지 전송 버튼 -->
            <Button Grid.Column="1"
                    Width="30" Height="30"
                    Margin="5 0"
                    ToolTip="이미지 보내기"
                    Command="{Binding SendFileCommand}">
                <TextBlock Text="📎" FontSize="14"/>
            </Button>

            <!-- 메시지 입력 -->
            <TextBox Grid.Column="2"
                     Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                     Height="40"
                     Margin="10 0"
                     VerticalContentAlignment="Center"/>

            <!-- 전송 버튼 -->
            <Button Grid.Column="3"
                    Content="전송"
                    Height="40"
                    Padding="10 0"
                    Command="{Binding SendMessageCommand}"/>
        </Grid>
    </Grid>
</UserControl>
